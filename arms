import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
       int n=sc.nextInt();
       int temp=n;
       int s=Integer.toString(n).length();
       int sum=0;
       while(n!=0){
           int digit=n%10;
           sum+=(int)Math.pow(digit,s);
           n=n/10;
       }
       if(sum==temp){
           System.out.print("yes");
           return;
       }
       System.out.print("no");
    }
}
