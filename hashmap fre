import java.util.*;
class Main {
    public static void main(String[] args) {
   String str="aaaabbccdd";
   HashMap<Character,Integer> m=new HashMap<>();
   for(int i=0;i<str.length();i++)
   {
       char c=str.charAt(i);
       m.put(c,m.getOrDefault(c,0)+1);
   }
   System.out.print(m);
    }
}
