import java.util.*;
class Main {
    public static void main(String[] args) {
      String str="asdsf1234%&rbdc";
      int l=0;
      int n=0;
      int s=0;
      for(char c:str.toCharArray()){
          if(Character.isLetter(c)){
              l++;
          }
          else if(Character.isDigit(c)){
              n++;
          }
          else {
              s++;
          }
      }
      System.out.println(l);
      System.out.println(n);
      System.out.println(s);
    }
}
