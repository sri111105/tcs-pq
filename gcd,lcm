import java.util.*;
class Main {
    public static int getgcd(int a, int b){
        while(b!=0){
            int temp=b;
            b=a%b;
            a=temp;
        }
        return a;
    }
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n1=sc.nextInt();
        int n2=sc.nextInt();
        
        int gcd=getgcd(n1,n2);
        int lcm=(n1*n2)/gcd;
        
        System.out.print(gcd);
        System.out.print(lcm);
    }
}
