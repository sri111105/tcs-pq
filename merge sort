import java.util.*;

class Main {
    public static void main(String[] args) {
        int arr[] = {1,2,3};
        int arr1[]={4,5,6};
        int[] arr3=new int[arr.length+arr1.length];
        for(int i=0;i<arr.length;i++){
            arr3[i]=arr[i];
            arr3[i+arr1.length]=arr1[i];
        }
        System.out.print(Arrays.toString(arr3));
    }
}
